---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { education, profile } from '../data/site';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const latestNotes = (await getCollection('notes'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);

const latestEssays = (await getCollection('essays'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);

const latestPosts = [...latestNotes, ...latestEssays]
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-page">
			<section class="hero">
				<img
					class="avatar"
					src="/avatar.jpg"
					alt="YangHao avatar"
					width="128"
					height="128"
					onerror="this.onerror=null;this.src='/avatar-badge.svg';"
				/>
				<h1>{profile.name}</h1>
				<p class="hero-meta">
					<span>{profile.location}</span>
					<span>·</span>
					<a href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
				</p>
				<div class="about-block">
					<p class="eyebrow">About</p>
					<p class="hero-copy">{profile.intro}</p>
				</div>
			</section>

			<section class="education-panel">
				<div class="section-head">
					<p class="eyebrow">Education</p>
				</div>
				<div class="education-list">
					{education.map((item) => (
						<a class="education-item" href={item.href} style={`--education-accent:${item.accent};`}>
							<img
								class="education-watermark"
								src={item.badge}
								alt=""
								aria-hidden="true"
								width="320"
								height="320"
							/>
							<div class="education-copy">
								<p class="meta">{item.period}</p>
								<h2>{item.school}</h2>
								<p>{item.detail}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section class="entry-grid">
				<a class="entry-card" href="/notes">
					<h2>Notes</h2>
				</a>
				<a class="entry-card" href="/essays">
					<h2>Essays</h2>
				</a>
				<a class="entry-card" href="/projects">
					<h2>Projects</h2>
				</a>
				<a class="entry-card" href="/links">
					<h2>Links</h2>
				</a>
			</section>

			<section class="recent-posts panel">
				<div class="panel-heading">
					<p class="eyebrow">Recent Posts</p>
				</div>
				<ul>
					{latestPosts.map((post) => (
						<li>
							<a href={`/${post.collection}/${post.id}/`}>
								<div>
									<p class="meta">
										{post.collection === 'notes' ? `${post.data.section} · ${post.data.chapter}` : 'Essay'}
									</p>
									<h3>{post.data.title}</h3>
								</div>
								<p class="meta"><FormattedDate date={post.data.pubDate} /></p>
							</a>
						</li>
					))}
				</ul>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	.home-page {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 3rem 0 4rem;
	}

	.hero {
		max-width: 42rem;
		margin: 0 auto 2.75rem;
		text-align: center;
	}

	.eyebrow,
	.entry-label,
	.meta {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
	}

	.eyebrow,
	.entry-label {
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.avatar {
		width: 128px;
		height: 128px;
		border-radius: 50%;
		object-fit: cover;
		object-position: center;
		box-shadow: var(--box-shadow);
		margin-bottom: 1rem;
	}

	.hero h1 {
		font-size: 2.3rem;
		margin-bottom: 0.45rem;
	}

	.hero-meta {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.55rem;
		margin: 0 0 1.5rem;
		font-size: 0.98rem;
		color: rgb(var(--gray));
	}

	.hero-meta a {
		color: inherit;
		text-decoration: none;
	}

	.about-block {
		margin: 0 auto;
		max-width: 38rem;
	}

	.hero-copy {
		max-width: 38rem;
		margin: 0.45rem auto 0;
		font-size: 1rem;
		color: rgb(var(--gray-dark));
	}

	.education-panel {
		margin-bottom: 1.5rem;
		padding: 1.6rem 1.5rem;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(var(--gray), 0.16);
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: 1.5rem;
	}

	.section-head {
		margin-bottom: 0;
	}

	.education-list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.education-item {
		position: relative;
		display: block;
		overflow: hidden;
		padding: 1.45rem 1.65rem;
		text-decoration: none;
		color: inherit;
		border: 1px solid rgba(var(--gray), 0.2);
		border-radius: 30px;
		background: rgba(255, 255, 255, 0.82);
		box-shadow: 0 10px 24px rgba(var(--black), 0.05);
	}

	.education-item:first-child {
		padding-top: 1.45rem;
	}

	.education-watermark {
		position: absolute;
		right: -4.5rem;
		top: 50%;
		transform: translateY(-50%);
		width: 360px;
		height: 360px;
		opacity: 0.24;
		pointer-events: none;
		filter: saturate(0.9);
	}

	.education-copy {
		min-width: 0;
		position: relative;
		z-index: 1;
		max-width: 58%;
	}

	.education-item h2 {
		font-size: 1.95rem;
		margin: 0 0 0.28rem;
		font-family: "FZFangSong-Z02", "STFangsong", "FangSong", "Songti SC", serif;
		font-weight: 700;
		color: var(--education-accent);
	}

	.education-item > div p {
		margin: 0;
		font-family: "FZFangSong-Z02", "STFangsong", "FangSong", "Songti SC", serif;
		font-size: 1.08rem;
		color: rgb(var(--gray-dark));
	}

	.education-item .meta {
		margin-bottom: 0.75rem;
		font-size: 0.98rem;
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
	}

	.entry-grid {
		display: grid;
		gap: 1.25rem;
	}

	.entry-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-bottom: 1.25rem;
	}

	.entry-card,
	.panel {
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(var(--gray), 0.16);
	}

	.entry-card {
		padding: 1rem 1.2rem;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: 72px;
	}

	.entry-card h2 {
		font-size: clamp(1.3rem, 2.2vw, 1.8rem);
		margin: 0;
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
	}

	.panel {
		padding: 1.5rem;
	}

	.panel-heading {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.panel ul {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
	}

	.panel li a {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.8rem 0;
		text-decoration: none;
		color: inherit;
		border-top: 1px solid rgba(var(--gray), 0.14);
	}

	.panel li:first-child a {
		padding-top: 0;
		border-top: none;
	}

	.panel h3 {
		font-size: 0.98rem;
		font-weight: 600;
		margin: 0.18rem 0 0;
	}

	.panel p:last-child {
		margin-bottom: 0;
	}

	.recent-posts {
		margin-bottom: 1.25rem;
	}

	.recent-posts ul {
		margin-top: 0.6rem;
	}

	.recent-posts li a {
		align-items: baseline;
	}

	.recent-posts .meta {
		font-size: 0.84rem;
	}

	.recent-posts p {
		margin: 0;
	}

	@media (max-width: 1100px) {
		.entry-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.entry-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 900px) {
		.entry-grid {
			grid-template-columns: 1fr;
		}

		.education-panel {
			grid-template-columns: 1fr;
		}

		.education-list {
			grid-template-columns: 1fr;
		}

		.education-copy {
			max-width: 100%;
		}

		.education-item {
			padding: 1.2rem 1.1rem;
			border-radius: 22px;
		}

		.education-watermark {
			width: 220px;
			height: 220px;
			right: -2.5rem;
		}

		.education-item h2 {
			font-size: 1.45rem;
		}

		.panel li a {
			flex-direction: column;
		}
	}
</style>
