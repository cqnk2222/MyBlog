---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const essays = (await getCollection('essays')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Essays" description="Short essays about learning, life, and the process of building." />
	</head>
	<body>
		<Header />
		<main class="essays-page">
			<h1 class="page-title">Essays</h1>
			<section class="essay-list">
				{essays.map((essay) => (
					<article>
						<a href={`/essays/${essay.id}/`}>
							<p class="date"><FormattedDate date={essay.data.pubDate} /></p>
							<h2>{essay.data.title}</h2>
							<p>{essay.data.description}</p>
						</a>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.essays-page {
		width: min(820px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 2.4rem 0 4rem;
	}

	.page-title {
		margin-bottom: 1.6rem;
		font-size: 1.15rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgb(var(--gray));
	}

	.eyebrow,
	.date {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.essay-list {
		display: grid;
		gap: 0;
	}

	.essay-list article {
		border-top: 1px solid rgba(var(--gray), 0.18);
	}

	.essay-list a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding: 1rem 0;
		color: inherit;
		text-decoration: none;
	}

	h2 {
		margin: 0.28rem 0 0.2rem;
		font-size: clamp(1rem, 1.45vw, 1.12rem);
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
		line-height: 1.25;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.essay-list p:last-child {
		margin-bottom: 0;
	}

	.essay-list article p:not(.date) {
		font-size: 0.95rem;
		margin: 0;
		max-width: 36rem;
	}

	@media (max-width: 720px) {
		.essay-list a {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
