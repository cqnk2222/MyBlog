---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About" description="About YangHao and the purpose of this site." />
	</head>
	<body>
		<Header />
		<main class="about-page">
			<section class="intro">
				<p class="eyebrow">About</p>
				<h1>Building a small home for notes, essays, and projects.</h1>
				<p>
					I am an AI student using this site as a long-term workspace for learning in public. Some
					sections are meant to be practical and structured, others are deliberately slower and more
					personal.
				</p>
			</section>
			<section class="about-grid">
				<article>
					<h2>What this site is for</h2>
					<p>
						Notes hold technical material that I want to revisit later. Essays are for personal
						reflection and writing that does not fit a handbook format. Projects track what I am building.
					</p>
				</article>
				<article>
					<h2>What I am studying</h2>
					<p>
						My current focus is AI-related coursework, paper reading, and implementation details. I care
						most about understanding ideas well enough to explain and reproduce them.
					</p>
				</article>
				<article>
					<h2>How I want the site to feel</h2>
					<p>
						Clear structure for notes, minimal reading experience for essays, and compact navigation for
						projects and links. The goal is not volume. The goal is reusability.
					</p>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		width: min(960px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 3rem 0 4rem;
	}

	.intro {
		max-width: 48rem;
		margin-bottom: 2.5rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.about-grid {
		display: grid;
		gap: 1.25rem;
	}

	.about-grid article {
		padding: 1.5rem;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(var(--gray), 0.16);
	}
</style>
