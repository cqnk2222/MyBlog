---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const notes = (await getCollection('notes')).sort((a, b) => {
	if (a.data.section !== b.data.section) {
		return a.data.section.localeCompare(b.data.section);
	}
	return a.data.order - b.data.order;
});

const groupedNotes = notes.reduce(
	(groups, note) => {
		const list = groups.get(note.data.section) ?? [];
		list.push(note);
		groups.set(note.data.section, list);
		return groups;
	},
	new Map<string, typeof notes>(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Notes" description="Structured notes on AI courses, papers, and technical topics." />
	</head>
	<body>
		<Header />
		<main class="notes-page">
			<section class="notes-sections">
				{Array.from(groupedNotes.entries()).map(([section, items]) => (
					<section class="section-card">
						<header>
							<h2>{section}</h2>
						</header>
						<ol>
							{items.map((note) => (
								<li>
									<a href={`/notes/${note.id}/`}>
										<div>
											<p class="chapter">{note.data.chapter}</p>
											<h3>{note.data.title}</h3>
											<p class="summary">{note.data.description}</p>
										</div>
										<p class="date"><FormattedDate date={note.data.pubDate} /></p>
									</a>
								</li>
							))}
						</ol>
					</section>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.notes-page {
		width: min(980px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 2.25rem 0 4rem;
	}

	.chapter,
	.date {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
	}

	.notes-sections {
		display: grid;
		gap: 1rem;
	}

	.section-card {
		padding: 0;
	}

	.section-card ol {
		list-style: none;
		padding: 0;
		margin: 0.6rem 0 0;
		display: grid;
		gap: 0;
	}

	.section-card li a {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.85rem 0;
		border-top: 1px solid rgba(var(--gray), 0.14);
		color: inherit;
		text-decoration: none;
	}

	.section-card li:first-child a {
		padding-top: 0.85rem;
	}

	h2 {
		margin-bottom: 0;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
	}

	h3 {
		margin: 0.18rem 0 0.22rem;
		font-size: 1rem;
	}

	.summary {
		margin: 0;
		max-width: 38rem;
		font-size: 0.96rem;
	}

	@media (max-width: 720px) {
		.section-card li a {
			flex-direction: column;
		}
	}
</style>
