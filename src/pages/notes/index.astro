---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { noteSpaces } from '../../data/notes';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Notes" description="Structured notes on AI courses, papers, and technical topics." />
	</head>
	<body>
		<Header />
		<main class="notes-page">
			<h1 class="page-title">Notes</h1>
			<section class="notes-list">
				{noteSpaces.map((space) => (
					<article>
						<a href={space.href} target="_blank" rel="noreferrer">
							<h2>{space.title}</h2>
							<p class="open-label">Open</p>
						</a>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.notes-page {
		width: min(820px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 2.4rem 0 4rem;
	}

	.page-title {
		margin-bottom: 1.6rem;
		font-size: 1.15rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgb(var(--gray));
	}

	.notes-list {
		display: grid;
		gap: 0;
	}

	.notes-list article {
		border-top: 1px solid rgba(var(--gray), 0.18);
	}

	.notes-list a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0;
		color: inherit;
		text-decoration: none;
	}

	h2 {
		margin: 0;
		font-size: clamp(1rem, 1.45vw, 1.12rem);
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
		line-height: 1.25;
	}

	.open-label {
		margin: 0;
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 720px) {
		.notes-list a {
			align-items: flex-start;
		}
	}
</style>
